# Copy this file to .env and fill in your API keys

# AI backend selection: claude | openai | ollama
REVERSER_BACKEND=claude

# Anthropic (Claude) settings
ANTHROPIC_API_KEY=your_anthropic_key_here
REVERSER_CLAUDE_MODEL=claude-opus-4-5

# OpenAI settings
OPENAI_API_KEY=your_openai_key_here
REVERSER_OPENAI_MODEL=gpt-4o

# Ollama settings (no key required)
REVERSER_OLLAMA_HOST=http://localhost:11434
REVERSER_OLLAMA_MODEL=llama3
